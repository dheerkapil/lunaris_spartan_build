name: Build Lunaris for spartan

on:
  workflow_dispatch:

jobs:
  sync:
    name: Sync Source
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Maximize disk space
        run: |
          # Community‑standard cleanup for AOSP builds
          sudo rm -rf /usr/share/dotnet /usr/local/lib/android /opt/ghc
          sudo rm -rf /usr/local/.ghcup /usr/local/share/powershell /usr/local/share/chromium
          sudo rm -rf /usr/local/lib/node_modules /opt/microsoft /opt/pipx
          sudo rm -rf /opt/hostedtoolcache/CodeQL /opt/hostedtoolcache/Python
          sudo rm -rf /opt/hostedtoolcache/Ruby /opt/hostedtoolcache/go
          sudo rm -rf /opt/hostedtoolcache/Java_* /opt/hostedtoolcache/dotnet
          sudo rm -rf /usr/share/swift /usr/local/graalvm /usr/local/share/boost
          sudo apt-get purge -y '^ghc.*' '^llvm.*' '^mono.*' '^php.*' '^postgresql.*' '^temurin.*' '^zulu.*' '^dotnet.*' '^mysql.*' '^oracle.*' 2>/dev/null || true
          sudo apt-get autoremove -y && sudo apt-get clean
          sudo docker system prune -af 2>/dev/null || true
          # Remove swap file if present (we don't need it for sync)
          sudo swapoff -a 2>/dev/null || true
          sudo rm -f /mnt/swapfile 2>/dev/null || true
          df -h /

      - name: Install build dependencies
        run: |
          sudo apt-get update -y
          sudo apt-get install -y openjdk-11-jdk-headless git-core gnupg flex bison \
            gperf build-essential zip curl zlib1g-dev gcc-multilib g++-multilib \
            libc6-dev-i386 libncurses5-dev libssl-dev liblz4-tool x11proto-core-dev \
            libx11-dev libgl1-mesa-dev xsltproc unzip python-is-python3 imagemagick \
            pngcrush rsync bc libxml2-utils

      - name: Set up repo tool
        run: |
          mkdir -p ~/bin
          curl -s https://storage.googleapis.com/git-repo-downloads/repo > ~/bin/repo
          chmod a+x ~/bin/repo
          echo "$HOME/bin" >> $GITHUB_PATH

      - name: Configure git
        run: |
          git config --global user.name "GitHub Actions"
          git config --global user.email "actions@github.com"

      - name: Generate cache key
        id: cache-key
        run: |
          echo "key=lunaris-16.2-$(md5sum $GITHUB_WORKSPACE/local_manifest.xml | cut -d ' ' -f1)" >> $GITHUB_OUTPUT

      - name: Cache Android source
        id: cache-source
        uses: actions/cache@v4
        with:
          path: ~/aosp
          key: ${{ steps.cache-key.outputs.key }}-sync

      - name: Init and sync source (if no cache hit)
        if: steps.cache-source.outputs.cache-hit != 'true'
        run: |
          mkdir -p ~/aosp
          cd ~/aosp
          repo init -u https://github.com/Lunaris-AOSP/android -b 16.2 --git-lfs
          mkdir -p .repo/local_manifests
          cp $GITHUB_WORKSPACE/local_manifest.xml .repo/local_manifests/
          # Sync without downloading LFS blobs to save disk space
          GIT_LFS_SKIP_SMUDGE=1 repo sync -c -j$(nproc --all) --force-sync --no-clone-bundle --no-tags

      - name: Update source (if cache existed)
        if: steps.cache-source.outputs.cache-hit == 'true'
        run: |
          cd ~/aosp
          GIT_LFS_SKIP_SMUDGE=1 repo sync -c -j$(nproc --all) --force-sync --no-clone-bundle --no-tags

  build:
    name: Build ROM
    needs: sync
    runs-on: ubuntu-latest
    env:
      WITH_GMS: true
      WITH_GMS_COMMS_SUITE: false
      TARGET_CUSTOM_UDFPS: true

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Maximize disk space
        run: |
          sudo rm -rf /usr/share/dotnet /usr/local/lib/android /opt/ghc
          sudo rm -rf /usr/local/.ghcup /usr/local/share/powershell /usr/local/share/chromium
          sudo rm -rf /usr/local/lib/node_modules /opt/microsoft /opt/pipx
          sudo rm -rf /opt/hostedtoolcache/CodeQL /opt/hostedtoolcache/Python
          sudo rm -rf /opt/hostedtoolcache/Ruby /opt/hostedtoolcache/go
          sudo rm -rf /opt/hostedtoolcache/Java_* /opt/hostedtoolcache/dotnet
          sudo rm -rf /usr/share/swift /usr/local/graalvm /usr/local/share/boost
          sudo apt-get purge -y '^ghc.*' '^llvm.*' '^mono.*' '^php.*' '^postgresql.*' '^temurin.*' '^zulu.*' '^dotnet.*' '^mysql.*' '^oracle.*' 2>/dev/null || true
          sudo apt-get autoremove -y && sudo apt-get clean
          sudo docker system prune -af 2>/dev/null || true
          sudo swapoff -a 2>/dev/null || true
          sudo rm -f /mnt/swapfile 2>/dev/null || true
          df -h /

      - name: Install build dependencies
        run: |
          sudo apt-get update -y
          sudo apt-get install -y openjdk-11-jdk-headless git-core gnupg flex bison \
            gperf build-essential zip curl zlib1g-dev gcc-multilib g++-multilib \
            libc6-dev-i386 libncurses5-dev libssl-dev liblz4-tool x11proto-core-dev \
            libx11-dev libgl1-mesa-dev xsltproc unzip python-is-python3 imagemagick \
            pngcrush rsync bc libxml2-utils

      - name: Set up repo tool
        run: |
          mkdir -p ~/bin
          curl -s https://storage.googleapis.com/git-repo-downloads/repo > ~/bin/repo
          chmod a+x ~/bin/repo
          echo "$HOME/bin" >> $GITHUB_PATH

      - name: Configure git
        run: |
          git config --global user.name "GitHub Actions"
          git config --global user.email "actions@github.com"

      - name: Generate cache key
        id: cache-key
        run: |
          echo "key=lunaris-16.2-$(md5sum $GITHUB_WORKSPACE/local_manifest.xml | cut -d ' ' -f1)" >> $GITHUB_OUTPUT

      - name: Restore cached source
        uses: actions/cache@v4
        with:
          path: ~/aosp
          key: ${{ steps.cache-key.outputs.key }}-sync

      - name: Quick sync (update if needed)
        run: |
          cd ~/aosp
          GIT_LFS_SKIP_SMUDGE=1 repo sync -c -j$(nproc --all) --force-sync --no-clone-bundle --no-tags

      - name: Fetch LFS objects (actual large blobs)
        run: |
          cd ~/aosp
          repo forall -c 'git lfs pull'

      - name: Set up build environment and lunch
        run: |
          cd ~/aosp
          . build/envsetup.sh
          lunch lineage_spartan-userdebug

      - name: Build ROM
        run: |
          cd ~/aosp
          make bacon -j$(nproc --all)

      - name: Upload ROM artifact
        uses: actions/upload-artifact@v4
        with:
          name: Lunaris-spartan-${{ github.run_id }}
          path: ~/aosp/out/target/product/spartan/*.zip