- name: Setup and validate local manifest
  run: |
    set -e

    MANIFEST_DIR="$HOME/aosp/.repo/local_manifests"
    MANIFEST_FILE="$MANIFEST_DIR/local_manifest.xml"

    # Ensure the directory exists
    mkdir -p "$MANIFEST_DIR"

    # Copy the manifest from workspace (if provided)
    if [ -f "$GITHUB_WORKSPACE/local_manifest.xml" ]; then
      cp "$GITHUB_WORKSPACE/local_manifest.xml" "$MANIFEST_FILE"
      echo "Copied local_manifest.xml from workspace"
    else
      echo "No local_manifest.xml found in workspace – creating a default one."
    fi

    # If the file doesn't exist or is empty, create a valid skeleton
    if [ ! -s "$MANIFEST_FILE" ]; then
      cat > "$MANIFEST_FILE" <<'EOF'
    <?xml version="1.0" encoding="UTF-8"?>
    <manifest>
      <!-- Add your project overrides here -->
    </manifest>
    EOF
      echo "Created default local_manifest.xml"
    fi

    # Show content for debugging
    echo "--- Content of local_manifest.xml ---"
    cat "$MANIFEST_FILE"
    echo "--- End of content ---"

    # Install xmllint if not present (should be available on Ubuntu runners)
    sudo apt-get update && sudo apt-get install -y libxml2-utils dos2unix

    # Fix possible BOM and CRLF issues
    dos2unix "$MANIFEST_FILE" 2>/dev/null || true
    sed -i '1s/^\xEF\xBB\xBF//' "$MANIFEST_FILE"

    # Validate the XML
    if ! xmllint --noout "$MANIFEST_FILE" 2>/dev/null; then
      echo "❌ Invalid XML detected. Attempting to fix common errors..."

      # Try to wrap content if root is missing (add <manifest> if not present)
      if ! grep -q "<manifest" "$MANIFEST_FILE"; then
        echo "Missing <manifest> root – adding it."
        sed -i '1i<?xml version="1.0" encoding="UTF-8"?>\n<manifest>' "$MANIFEST_FILE"
        echo "</manifest>" >> "$MANIFEST_FILE"
      fi

      # Escape unescaped ampersands (&) – simplistic but helps
      sed -i 's/&\([^a-zA-Z#]\|$\)/\&amp;\1/g' "$MANIFEST_FILE"

      # Re-validate
      if xmllint --noout "$MANIFEST_FILE" 2>/dev/null; then
        echo "✅ Fixed XML – validation passed."
      else
        echo "⚠️  Still invalid. Replacing with a minimal valid manifest."
        cat > "$MANIFEST_FILE" <<'EOF'
    <?xml version="1.0" encoding="UTF-8"?>
    <manifest>
      <project name="Lunaris-AOSP/android" path="." revision="16.2" />
    </manifest>
    EOF
        echo "Replaced with fallback manifest."
      fi
    else
      echo "✅ local_manifest.xml is valid."
    fi

- name: Repo sync
  run: |
    cd ~/aosp
    repo sync -c -j$(nproc --all) --force-sync --no-clone-bundle --no-tags